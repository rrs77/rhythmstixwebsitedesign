{
  "buildCommand": "pnpm --filter @workspace/rhythmstix-web run build",
  "outputDirectory": "artifacts/rhythmstix-web/dist/public",
  "framework": "vite",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
