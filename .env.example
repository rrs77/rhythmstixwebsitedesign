# API port (must match Vite proxy target below unless you set API_URL)
PORT=3001

# Optional: Vite dev only — base URL of the Express API for proxying /api (default http://127.0.0.1:3001)
# API_URL=http://127.0.0.1:8080

# Required for WooCommerce product/order integration
WC_CONSUMER_KEY=ck_xxxxx
WC_CONSUMER_SECRET=cs_xxxxx

# Required for user auth and admin
SESSION_SECRET=your-random-secret-string
ADMIN_PASSWORD=your-admin-password

# Required for PostgreSQL database (Neon, Supabase, etc.)
# Local Docker: run `docker compose up -d` then use:
# DATABASE_URL=postgresql://rhythmstix:rhythmstix@localhost:5432/rhythmstix
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Optional — YouTube channel for the /blog “Latest Content” feed (merged with WordPress + LinkedIn).
# Uses YouTube’s public RSS — no API key. Default matches @RhythmstixMusicForEducation (UC…).
# Set either the channel ID or a /channel/UC… URL; @handle-only URLs need the UC id instead.
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
# YOUTUBE_CHANNEL_URL=https://www.youtube.com/channel/UCxxxxxxxxxxxxxxxxxxxxxx

# Optional - Mailchimp email subscription
MAILCHIMP_API_KEY=xxxxx-us1
MAILCHIMP_LIST_ID=xxxxx

# Optional - Vercel auto-provides these
# VERCEL_URL=your-project.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=your-domain.com
